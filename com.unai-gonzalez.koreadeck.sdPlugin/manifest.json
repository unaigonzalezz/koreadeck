      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/common/bg",
          "TitleAlignment": "middle",
          "FontSize": 30
        }
      ]
    },
    {
      "Name": "Reader settings",
      "UUID": "com.unai-gonzalez.koreadeck.reader-settings",
      "Icon": "imgs/actions/reader-settings/icon",
      "Tooltip": "Open settings for the currently active document.",
