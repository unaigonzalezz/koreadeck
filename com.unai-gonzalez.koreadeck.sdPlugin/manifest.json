{
  "Name": "KOReadeck",
  "Version": "1.0.0.0",
  "Author": "Unai González",
  "Actions": [
    {
      "Name": "Configuration",
      "UUID": "com.unai-gonzalez.koreadeck.set-config",
      "Icon": "imgs/actions/config/icon",
      "Tooltip": "Set up your KOReader device connection (IP, port, and timeout).",
      "Controllers": [
        "Keypad"
      ],
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/actions/config/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Open last document",
      "UUID": "com.unai-gonzalez.koreadeck.open-last-document",
      "Icon": "imgs/actions/open-last-document/icon",
      "Tooltip": "Reopen your last read document instantly.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/open-last-document/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Change page",
      "UUID": "com.unai-gonzalez.koreadeck.change-page",
      "Icon": "imgs/actions/view/key",
      "Tooltip": "Navigate your book by turning pages forward or backward.",
