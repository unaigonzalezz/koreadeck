        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/frontlight-brightness/increase",
          "TitleAlignment": "middle",
          "FontSize": 24
        }
      ]
    },
    {
      "Name": "Change screen orientation",
      "UUID": "com.unai-gonzalez.koreadeck.change-orientation",
      "Icon": "imgs/actions/change-orientation/icon",
      "Tooltip": "Switch between portrait and landscape screen orientation.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/change-orientation/portrait",
          "TitleAlignment": "middle",
          "Name": "Portrait"
        },
        {
          "Image": "imgs/actions/change-orientation/landscape",
          "TitleAlignment": "middle",
          "Name": "Landscape"
        }
      ]
    },
    {
      "Name": "Book info",
      "UUID": "com.unai-gonzalez.koreadeck.get-book-info",
      "Icon": "imgs/actions/get-book-info/icon",
      "Tooltip": "Display the current book cover and reading information.",
      "PropertyInspectorPath": "ui/get-book-info.html",
      "Controllers": [
        "Keypad"
      ],
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/actions/get-book-info/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "Name": "Battery level",
      "UUID": "com.unai-gonzalez.koreadeck.battery-level",
      "Icon": "imgs/actions/battery-level/icon",
      "Tooltip": "Display the current battery level of your KOReader device.",
      "PropertyInspectorPath": "ui/battery-level.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/battery-level/key-4",
          "TitleAlignment": "middle",
          "FontSize": 20
        }
      ]
    },
    {
      "Name": "Screen preview",
      "UUID": "com.unai-gonzalez.koreadeck.screen-preview",
      "Icon": "imgs/actions/screen-preview/icon",
      "Tooltip": "Open a live preview of your KOReader screen in your browser.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/screen-preview/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Take screenshot",
      "UUID": "com.unai-gonzalez.koreadeck.take-screenshot",
      "Icon": "imgs/actions/take-screenshot/icon",
      "Tooltip": "Capture the current KOReader screen and save it to your device.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/take-screenshot/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Restart KOReader",
      "UUID": "com.unai-gonzalez.koreadeck.restart-koreader",
      "Icon": "imgs/actions/restart-koreader/icon",
      "Tooltip": "Restart KOReader remotely.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/restart-koreader/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Exit KOReader",
      "UUID": "com.unai-gonzalez.koreadeck.exit-koreader",
      "Icon": "imgs/actions/exit-koreader/icon",
      "Tooltip": "Close KOReader remotely. You will need to restart it manually.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/exit-koreader/key",
          "TitleAlignment": "middle"
        }
      ]
    }
