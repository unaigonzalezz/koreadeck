      ],
      "States": [
        {
          "Image": "imgs/actions/toggle-frontlight/off",
          "TitleAlignment": "middle",
          "Name": "Frontlight OFF"
        },
        {
          "Image": "imgs/actions/toggle-frontlight/on",
          "TitleAlignment": "middle",
          "Name": "Frontlight ON"
        }
      ]
    },
    {
      "Name": "Frontlight brightness",
      "UUID": "com.unai-gonzalez.koreadeck.set-frontlight-brightness",
