      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/reader-settings/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Status bar",
      "UUID": "com.unai-gonzalez.koreadeck.status-bar",
      "Icon": "imgs/actions/status-bar/icon",
      "Tooltip": "Show or toggle the KOReader status bar.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/status-bar/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Show bookmarks",
      "UUID": "com.unai-gonzalez.koreadeck.view-bookmarks",
      "Icon": "imgs/actions/view-bookmarks/icon",
      "Tooltip": "Open the bookmarks list for the current book.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/view-bookmarks/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Toggle bookmark on current page",
      "UUID": "com.unai-gonzalez.koreadeck.toggle-bookmark-current-page",
      "Icon": "imgs/actions/toggle-bookmark/icon",
      "Tooltip": "Add or remove a bookmark on the current page.",
      "PropertyInspectorPath": "ui/general.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/toggle-bookmark/key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Toggle night mode",
      "UUID": "com.unai-gonzalez.koreadeck.toggle-screen-mode",
      "Icon": "imgs/actions/toggle-dark/icon",
